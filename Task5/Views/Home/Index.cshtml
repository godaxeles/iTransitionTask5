@{
    Layout = null;
    ViewData["Title"] = "MusicStore";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>MusicStore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app.css"/>
</head>
<body>

<div class="wrap">

    <div class="head">
        <span class="logo" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>
        </span>
        <span class="brand">MusicStore</span>
        <span class="sub">Catalogue · Seed <b id="seed-indicator">0</b></span>
    </div>

    <h1>The Fake Music Catalogue</h1>
    <p class="lede">A deterministic catalogue of songs that do not exist. Change the seed and the world resets.</p>

    <div class="controls">

        <div class="ctrl">
            <div class="ctrl-label"><span>Locale</span></div>
            <select class="field" id="locale" aria-label="Locale"></select>
        </div>

        <div class="ctrl">
            <div class="ctrl-label"><span>Seed</span></div>
            <div class="seed-row">
                <input class="field" id="seed" type="text" inputmode="numeric" pattern="-?\d+" placeholder="0"/>
                <button class="reseed" id="random-seed" type="button" title="New random seed" aria-label="Random seed">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7M21 3v6h-6"/></svg>
                </button>
            </div>
        </div>

        <div class="ctrl">
            <div class="ctrl-label"><span>Likes threshold</span><span class="val" id="likes-value">0.0 / 10</span></div>
            <div class="likes-wrap">
                <input type="range" class="likes-slider" id="likes" min="0" max="10" step="0.1" value="0"/>
            </div>
        </div>

        <div class="ctrl">
            <div class="ctrl-label"><span>View</span></div>
            <div class="view">
                <button class="vt active" id="view-table" type="button" data-view="table">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
                    List
                </button>
                <button class="vt" id="view-gallery" type="button" data-view="gallery">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                    Grid
                </button>
            </div>
        </div>

        <div class="ctrl">
            <div class="ctrl-label">&nbsp;</div>
            <button class="export" id="export-zip" type="button" title="Export current page as ZIP of MP3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                <span class="export-label">Export</span>
            </button>
        </div>

    </div>

    <div class="count">
        <div id="count-line"><b id="count-num">0</b> songs · sorted by likes</div>
        <div id="page-line">Page <b id="page-num">1</b></div>
    </div>

    <div class="view-wrap">

        <section id="table-section" class="view-section active">
            <div class="rows">
                <div class="thead">
                    <div class="center">#</div>
                    <div></div>
                    <div>Title</div>
                    <div>Artist</div>
                    <div>Album</div>
                    <div>Genre</div>
                    <div class="right">Likes</div>
                </div>
                <div id="rows-body"></div>
            </div>
            <div id="pagination-container" class="pager"></div>
        </section>

        <section id="gallery-section" class="view-section">
            <div class="gallery" id="gallery-grid"></div>
            <div id="gallery-sentinel" class="scroll-status">
                <span class="spinner" aria-hidden="true"></span>Loading more songs…
            </div>
        </section>

    </div>

</div>

<audio id="global-audio" preload="metadata"></audio>

<div class="player" id="player">
    <div class="pl-track">
        <div class="pl-cover" id="pl-cover"></div>
        <div class="pl-info">
            <div class="pl-title" id="pl-title">Select a track</div>
            <div class="pl-artist" id="pl-artist">—</div>
        </div>
    </div>
    <div class="pl-center">
        <div class="pl-ctrls">
            <button type="button" class="pl-secondary" id="pl-prev" title="Previous" aria-label="Previous">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 20L9 12l10-8v16zM5 5h2v14H5z"/></svg>
            </button>
            <button type="button" class="pl-play" id="pl-play" title="Play/Pause" aria-label="Play/Pause">
                <span class="pl-play-inner">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </span>
            </button>
            <button type="button" class="pl-secondary" id="pl-next" title="Next" aria-label="Next">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 4l10 8-10 8V4zm12 1h2v14h-2z"/></svg>
            </button>
        </div>
        <div class="pl-progress">
            <div class="pl-time" id="pl-current">0:00</div>
            <div class="pl-bar" id="pl-bar">
                <div class="pl-bar-bg"><div class="pl-bar-fill" id="pl-fill"></div></div>
            </div>
            <div class="pl-time pl-time-dim" id="pl-duration">0:00</div>
        </div>
    </div>
    <div class="pl-right">
        <div class="vol">
            <button type="button" class="vol-btn" id="vol-btn" aria-label="Mute">
                <span class="vol-icon" id="vol-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5zM15 9a4 4 0 0 1 0 6M19 5a8 8 0 0 1 0 14"/></svg>
                </span>
            </button>
            <div class="vol-bar" id="vol-bar">
                <div class="vol-bar-bg"><div class="vol-bar-fill" id="vol-fill" style="width:100%"></div></div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="~/js/app.js"></script>
</body>
</html>
